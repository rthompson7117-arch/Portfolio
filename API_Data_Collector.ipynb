      "source": [
        "\n",
        "import requests\n",
        "\n",
        "url = \"https://api.coindesk.com/v1/bpi/currentprice.json\"\n",
        "\n",
        "data = requests.get(url).json()\n",
        "\n",
        "price = data[\"bpi\"][\"USD\"][\"rate\"]\n",
        "\n",
        "print(\"Bitcoin price:\", price)\n",
        "\n"
      ]
    }
